{
  "name": "n8n-as-code-monorepo",
  "version": "0.2.0",
  "private": true,
  "description": "n8n workflow ecosystem",
  "type": "module",
  "bin": {
    "n8n-as-code": "./packages/cli/dist/index.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run generate:nodes && tsc -b --force && npm run build --workspace=packages/skills --workspace=packages/cli --workspace=packages/sync --workspace=packages/vscode-extension",
    "build:sync": "cd packages/sync && npm run build",
    "build:cli": "cd packages/cli && npm run build",
    "build:extension": "cd packages/vscode-extension && npm run build",
    "extension:install": "node scripts/build-and-install.js",
    "extension:dev": "node scripts/setup-dev-link.js",
    "test": "node scripts/unified-test-report.mjs",
    "test:ci-local": "node scripts/test-ci-local.js",
    "validate-schema": "node scripts/validate-schema.js --schema ./packages/sync/src/assets/n8n-nodes-index.json",
    "generate:nodes": "node scripts/ensure-n8n-cache.cjs && node scripts/generate-n8n-index.cjs && node scripts/compare-extraction.mjs",
    "clean": "npm run clean --workspaces --if-present && rm -rf packages/*/dist packages/*/out packages/**/tsconfig.tsbuildinfo .n8n-cache/ node_modules/.cache",
    "release": "npm run build",
    "check-versions": "node scripts/check-version-consistency.js",
    "docs": "cd docs && npm start",
    "docs:build": "cd docs && npm run build",
    "docs:api": "node scripts/generate-api-docs.cjs",
    "docs:all": "npm run docs:api && npm run docs:build"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.2",
    "chokidar": "^5.0.0",
    "deep-equal": "^2.2.3",
    "dotenv": "^17.2.3",
    "flexsearch": "^0.8.212",
    "open": "^8.4.2"
  },
  "devDependencies": {
    "typedoc": "^0.28.16",
    "typescript": "^5.3.3"
  }
}
