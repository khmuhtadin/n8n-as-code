{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "separate-pull-requests": false,
  "group-pull-requests": true,
  "packages": {
    "packages/transformer": {
      "package-name": "@n8n-as-code/transformer",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/sync": {
      "package-name": "@n8n-as-code/sync",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/skills": {
      "package-name": "@n8n-as-code/skills",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/cli": {
      "package-name": "@n8n-as-code/cli",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/vscode-extension": {
      "package-name": "n8n-as-code",
      "changelog-path": "CHANGELOG.md"
    }
  },
  "plugins": [
    {
      "type": "node-workspace",
      "update-peer-dependencies": true
    }
  ]
}
